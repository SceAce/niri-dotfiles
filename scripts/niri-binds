#!/usr/bin/env bash

NIRI_DIR="$HOME/.config/niri"

# === 界面尺寸设置 (在这里微调，下方的所有终端会自动应用) ===
MENU_WIDTH=90
MENU_HEIGHT=20

# 检查目录
if [[ ! -d "$NIRI_DIR" ]]; then
    echo "Error: 找不到配置目录 $NIRI_DIR"
    exit 1
fi

# 提取并使用 column 对齐
MENU_ITEMS=$(grep -Rh 'hotkey-overlay-title=' "$NIRI_DIR" --include="*.kdl" | \
             grep -v '^[ \t]*//' | \
             sed -n -E 's/^[ \t]*(.*)[ \t]+hotkey-overlay-title="([^"]+)".*/\1|\2/p' | \
             sed -E 's/[ \t]*\|/\|/' | \
             column -t -s '|')

if [[ -z "$MENU_ITEMS" ]]; then
    echo "没有找到有效的快捷键配置。"
    exit 1
fi

if command -v rofi >/dev/null 2>&1; then
    echo "$MENU_ITEMS" | rofi -dmenu -i -p "Keybinds" -config "$HOME/.config/rofi/config-keybinds.rasi" > /dev/null
elif command -v fuzzel >/dev/null 2>&1; then
    echo "$MENU_ITEMS" | fuzzel --dmenu -i -p "󰌌 快捷键: " -w ${MENU_WIDTH} > /dev/null
elif command -v ghostty >/dev/null 2>&1; then
    ghostty --class "niri-hotkey-menu" -e bash -lc "printf '%s\n' \"$MENU_ITEMS\" | less -R"
else
    notify-send "niri" "快捷键帮助需要 rofi、fuzzel 或 ghostty"
    exit 1
fi
